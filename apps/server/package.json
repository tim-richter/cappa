{
  "name": "@cappa/server",
  "version": "0.5.6",
  "type": "module",
  "license": "MIT",
  "author": "Tim Richter",
  "files": [
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tim-richter/cappa.git"
  },
  "main": "dist/server.mjs",
  "types": "dist/server.d.mts",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "./bin/build.sh",
    "build:ts": "tsdown src/server.ts --format esm --target node20 --dts",
    "start": "NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@cappa/core": "workspace:*",
    "@fastify/compress": "^8.3.1",
    "@fastify/middie": "9.3.1",
    "@fastify/static": "9.1.0",
    "fastify": "5.8.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cappa/logger": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "memfs": "^4.56.11",
    "tsx": "4.21.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
